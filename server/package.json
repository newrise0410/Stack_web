{
  "name": "server",
  "version": "1.0.0",
  "description": "stacknstak API server (Node.js + Express + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed/seedProducts.js",
    "create:admin": "node src/scripts/createAdmin.mjs",
    "migrate:images": "node src/scripts/migrateImagesToCloudinary.mjs",
    "backfill:sku": "node src/scripts/backfillSkus.mjs",
    "purge:withdrawn": "node src/scripts/purgeWithdrawn.mjs",
    "sweep:images": "node src/scripts/sweepOrphanCloudinary.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
