# Server
PORT=4000

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/stacknstak

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS: 배포 후 프론트 도메인 지정 (쉼표로 여러 개). 미설정 시 전체 허용.
# 예: https://stacknstak.vercel.app
CLIENT_ORIGIN=

# Cloudinary — 아래 둘 중 하나만 설정하면 됨. 미설정 시 이미지 업로드만 503(그 외 기능 정상).
# (권장) 대시보드가 그대로 주는 단일 URL 형식 — 실제 값으로 바꾸고 주석(#)을 해제:
# CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
# (대안) 3개 분리 형식:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# 포트원(아임포트) v1 REST API 키 — 콘솔 > 결제연동 > 식별코드·API Keys
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=
